{
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/build",
  "functions": {
    "api/ask-claude.js": {
      "memory": 128,
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/summary",           "destination": "https://api.cloudandcapital.com/api/summary" },
    { "source": "/api/cost-trend",        "destination": "https://api.cloudandcapital.com/api/cost-trend" },
    { "source": "/api/service-breakdown", "destination": "https://api.cloudandcapital.com/api/service-breakdown" },
    { "source": "/api/top-movers",        "destination": "https://api.cloudandcapital.com/api/top-movers" },
    { "source": "/api/key-insights",      "destination": "https://api.cloudandcapital.com/api/key-insights" },
    { "source": "/api/products",          "destination": "https://api.cloudandcapital.com/api/products" },
    { "source": "/api/movers",            "destination": "https://api.cloudandcapital.com/api/movers" },
    { "source": "/(.*)",                  "destination": "/frontend/build/$1" }
  ]
}
